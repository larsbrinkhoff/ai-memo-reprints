1(DEFUN SCHEDULE ()
       (COND (**QUEUE**
	      (SWAPOUTPROCESS)
	      (NCONC **QUEUE** (LIST **PROCESS**))
	      (SETQ **PROCESS** (CAR **QUEUE**)
		    **QUEUE** (CDR **QUEUE**))
	      (SWAPINPROCESS)))
       (SETQ **TICK** NIL)
       (ALARMCLOCK 'RUNTIME **QUANTUM**))0
