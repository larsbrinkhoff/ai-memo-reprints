	(LAMBDA (SEXPR ENV CONT)
		(COND ((ATOM SEXPR) (CPC-ATOM SEXPR ENV CONT))
		      ((EQ (CAR SEXPR) 'QUOTE)
		       (IF CONT "(,CONT ,SEXPR) SEXPR))
		      ((EQ (CAR SEXPR) 'LAMBDA)
		       (CPC-LAMBDA SEXPR ENV CONT))
		      ((EQ (CAR SEXPR) 'IF)
		       (CPC-IF SEXPR ENV CONT))
		      ((EQ (CAR SEXPR) 'CATCH)
		       (CPC-CATCH SEXPR ENV CONT))
		      ((EQ (CAR SEXPR) 'LABELS)
		       (CPC-LABELS SEXPR ENV CONT))
		      ((AND (ATOM (CAR SEXPR))
			    (GET (CAR SEXPR) 'AMACRO))
