1(DEFUN SAPPLY ()					;Apply function in VAL to ARGS.
       (COND ((PRIMOP? VAL)				;If a primitive procedure,
	      (SETQ VAL (PRIMOP-APPLY VAL ARGS))	; do it!
	      (POPJ-RETURN))				; then return value to caller.
	     ((EQ (CAR VAL) '&PROCEDURE)		;If a defined procedure,
	      (SETQ ENV					; set up its environment
		    (BIND (CADR VAL)			; by binding the formals
			  ARGS				; to the actuals
			  (CADDDR VAL)))		; in the closure environment
	      (SETQ EXP (CADDR VAL))			; then get the procedure body
	      (EVAL-DISPATCH))				; and evaluate it.
	     (T (ERROR))))				;Otherwise, error.
