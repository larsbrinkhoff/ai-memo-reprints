		     (TYPE-DISPATCH EXP
				    ("NUMBER" EXP)
				    ("SYMBOL" EXP)
				    ("LIST" EXP)
				    ("VARIABLE" (DISPLAY-LOOKUP EXP ENV))
				    ("PROCEDURE" (TYPED-CONS "CLOSURE" (CDR EXP) ENV))
				    ("IF" (IF (EVAL (CAR EXP) ENV)
					      (EVAL (CADR EXP) ENV)
					      (EVAL (CDDR EXP) ENV)))
				    ("COMBINATION"  (EVCOMB (CDR EXP)
							    ENV
							    (CONS (EVAL (CAR EXP) ENV)
