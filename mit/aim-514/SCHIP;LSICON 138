1     (DEFINE BIND
	     (LAMBDA (VARS ARGS ENV)
		     (IF (= (LENGTH VARS) (LENGTH ARGS))
			 (CONS (CONS VARS ARGS) ENV)
			 (ERROR))))
.spw 16
.adjust
.sp
0

.nofill
.spw 13
.block 3
1     (DEFINE VALUE
	     (LAMBDA (NAME ENV)
		     (VALUE1 NAME (LOOKUP NAME ENV))))
.spw 16
.adjust
.sp
0

.nofill
.spw 13
.block 4
1     (DEFINE VALUE1
	     (LAMBDA (NAME SLOT)
		     (IF (EQ SLOT '&UNBOUND) (ERROR)
			 (CAR SLOT))))
.spw 16
